# KDTree
nPoint=10000                # n > P * (log_2 P)^3
nPim=64                     # P >= 2
dimensions=3                # 1 <= D <= 15
alpha=2.0                   # 0 < a < 8
beta=2.0                    # a/2 < b < 2a
leafWrapThreshold=32        # 1 <= 𝜙 <= 100
oversamplingRate=32         # log_2 n <= σ <= log_2^3 n
sketchHeight=6              # 4 <= 𝜆 <= 10
chunkSize=64                # 2^𝜆

# Logger
stream=stdout               # Use stdout or set filename in log/
severity=DEBUG              # ERROR / WARNING / DEBUG
